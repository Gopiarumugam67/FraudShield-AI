# ======================================================
# FraudShield AI Configuration
# ======================================================

# Application
APP_NAME=FraudShield AI
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# API
API_HOST=127.0.0.1
API_PORT=8000

# Paths
